# Apify API Configuration
# Get your token at: https://console.apify.com/settings/integrations
APIFY_TOKEN=your_apify_token_here

# Optional: Email notifications (for future enhancement)
# EMAIL_FROM=your_email@gmail.com
# EMAIL_TO=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password

# Optional: Slack notifications (for future enhancement)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional: Search preferences
# PREFERRED_LOCATIONS=Bangalore,Mumbai,Delhi,Hyderabad,Pune
# MIN_SALARY_LPA=30
# MAX_COMMUTE_TIME_MINS=45
